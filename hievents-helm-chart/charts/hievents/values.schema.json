{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "hieventsConfig": {
      "type": "object",
      "properties": {
        "storage": {
          "type": "object",
          "properties": {
            "driver": {
              "type": "string",
              "enum": ["s3", "local"]
            },
            "disk": { "type": "string" },
            "filesystemDriver": { "type": "string" },
            "publicDisk": { "type": "string" },
            "privateDisk": { "type": "string" }
          }
        },
        "app": {
          "type": "object",
          "properties": {
            "url": { "type": "string" },
            "frontendUrl": { "type": "string" },
            "viteApiUrlClient": { "type": "string" },
            "viteApiUrlServer": { "type": "string" },
            "viteFrontendUrl": { "type": "string" }
          }
        },
        "postgresql": {
          "type": "object",
          "properties": {
            "databaseUrl": { "type": "string" }
          }
        },
        "redis": {
          "type": "object",
          "properties": {
            "url": { "type": "string" }
          }
        },
        "jwt": {
          "type": "object",
          "properties": {
            "algo": { "type": "string" }
          }
        },
        "s3": { "type": "object" }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "app": {
          "type": "object",
          "properties": {
            "stripePublishableKeyKey": { "type": "string" },
            "stripePublishableKey": { "type": "string" },
            "stripeSecretKeyKey": { "type": "string" },
            "stripeSecretKey": { "type": "string" },
            "stripeWebhookSecretKey": { "type": "string" },
            "stripeWebhookSecret": { "type": "string" }
          }
        }
      }
    },
    "backend": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 },
        "image": {
          "type": "object",
          "properties": {
            "registry": { "type": "string" },
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "digest": { "type": "string" },
            "pullPolicy": { "type": "string" }
          }
        },
        "probes": { "type": "object" },
        "resources": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "existingClaim": { "type": "string" },
            "storageClass": { "type": "string" },
            "accessModes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "size": { "type": "string" },
            "mountPath": { "type": "string" }
          }
        }
      }
    },
    "frontend": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 },
        "image": {
          "type": "object",
          "properties": {
            "registry": { "type": "string" },
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "digest": { "type": "string" },
            "pullPolicy": { "type": "string" }
          }
        },
        "probes": { "type": "object" },
        "resources": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" }
      }
    },
    "webProxy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 },
        "image": {
          "type": "object",
          "properties": {
            "registry": { "type": "string" },
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "digest": { "type": "string" },
            "pullPolicy": { "type": "string" }
          }
        },
        "service": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "port": { "type": "integer" },
            "targetPort": { "type": "integer" }
          }
        },
        "probes": { "type": "object" },
        "resources": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" }
      }
    },
    "worker": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 },
        "resources": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" }
      }
    },
    "scheduler": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "resources": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" }
      }
    },
    "migration": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "useHelmHooks": { "type": "boolean" },
        "hookDeletePolicy": { "type": "string" },
        "resources": { "type": "object" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "redis": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "httpRoute": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "hostnames": {
          "type": "array",
          "items": { "type": "string" }
        },
        "parentRefs": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    }
  }
}
