package main

values: {
	// After the inital deployment, set to "false"
	initMode:           false

	// The following are the configurations of seafile container
	configs: {
		seafileFrontendReplicas: 2
		image:                   "seafileltd/seafile-pro-mc:13.0-latest"
		seafileDataVolume: {
			storage: "10Gi"
		}
