		// for cache
		CACHE_PROVIDER:                   "memcached"

		// for redis
		REDIS_HOST:                       "redis-master"
		REDIS_PORT:                       "6379"

		// for memcached
		MEMCACHED_HOST:                   "memcached"
		MEMCACHED_PORT:                   "11211"

		// S3
		SEAF_SERVER_STORAGE_TYPE:         "disk"
